# ── Core ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-django-key-change-this-NOW
DEBUG=True
ALLOWED_HOSTS=*

# ── Database: SQLite3 by default. Upgrade to PostgreSQL: ─────────────────────
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=formcraft
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432

# ── Email Notifications (Gmail SMTP) ─────────────────────────────────────────
# 1. Enable 2-Factor Auth on your Gmail account
# 2. Go to Google Account → Security → App Passwords → Create one
# 3. Paste the 16-char app password below (NOT your real password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=FormCraft <your-email@gmail.com>

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
